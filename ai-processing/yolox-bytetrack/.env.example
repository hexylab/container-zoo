# =============================================================================
# YOLOX + ByteTrack Environment - Configuration
# =============================================================================
# Copy this file to .env and customize the values for your environment
# Usage: cp .env.example .env

# =============================================================================
# CONTAINER CONFIGURATION
# =============================================================================

# Jupyter Lab Configuration
JUPYTER_PORT=8888
JUPYTER_TOKEN=your-secure-token-here
JUPYTER_ENABLE_LAB=yes

# Container Resources
CONTAINER_NAME=yolox-bytetrack-dev
WORKSPACE_PATH=/workspace
DATA_PATH=./data
MODELS_PATH=./models
OUTPUT_PATH=./output

# =============================================================================
# GPU CONFIGURATION
# =============================================================================

# NVIDIA GPU Settings
NVIDIA_VISIBLE_DEVICES=all
CUDA_VISIBLE_DEVICES=0

# GPU Memory Settings (optional)
# NVIDIA_DRIVER_CAPABILITIES=compute,utility
# NVIDIA_REQUIRE_CUDA=cuda>=11.0

# =============================================================================
# YOLOX CONFIGURATION
# =============================================================================

# Model Configuration
YOLOX_MODEL_SIZE=yolox_s
YOLOX_MODEL_PATH=models/yolox_s.pth
YOLOX_CONFIDENCE_THRESHOLD=0.5
YOLOX_NMS_THRESHOLD=0.45
YOLOX_INPUT_SIZE=640,640
YOLOX_TARGET_CLASSES=
YOLOX_DEVICE=auto

# Available model sizes: yolox_nano, yolox_tiny, yolox_s, yolox_m, yolox_l, yolox_x

# =============================================================================
# BYTETRACK CONFIGURATION
# =============================================================================

# Tracking Parameters
BYTETRACK_TRACK_THRESH=0.5
BYTETRACK_HIGH_THRESH=0.6
BYTETRACK_MATCH_THRESH=0.8
BYTETRACK_TRACK_BUFFER=30
BYTETRACK_FRAME_RATE=30
BYTETRACK_MIN_TRACK_LENGTH=10

# =============================================================================
# INPUT CONFIGURATION
# =============================================================================

# Input Source Settings
INPUT_TYPE=video
INPUT_SOURCE=data/input.mp4
INPUT_FPS_LIMIT=30
INPUT_MAX_WIDTH=1920
INPUT_MAX_HEIGHT=1080

# Available input types: webcam, video, rtsp, images, image
# Example sources:
# - Webcam: 0, 1, 2 (camera index)
# - Video: path/to/video.mp4
# - RTSP: rtsp://username:password@ip:port/stream
# - Images: path/to/images/folder
# - Image: path/to/image.jpg

# =============================================================================
# OUTPUT CONFIGURATION
# =============================================================================

# Output Paths
OUTPUT_DIR=output
OUTPUT_VIDEO_PATH=output/videos/result_{timestamp}.mp4
OUTPUT_VIDEO_CODEC=mp4v
OUTPUT_VIDEO_QUALITY=90

# Tracking Data
OUTPUT_TRACKING_DATA=true
OUTPUT_TRACKING_PATH=output/tracking_data/tracks_{timestamp}.json

# Frame Saving
OUTPUT_SAVE_FRAMES=false
OUTPUT_FRAMES_DIR=output/frames/{timestamp}
OUTPUT_FRAME_INTERVAL=30

# Logging
OUTPUT_LOG_ENABLED=true
OUTPUT_LOG_PATH=output/logs/log_{timestamp}.txt
OUTPUT_LOG_LEVEL=INFO

# =============================================================================
# DISPLAY CONFIGURATION
# =============================================================================

# Real-time Display
DISPLAY_SHOW_REALTIME=true
DISPLAY_WINDOW_WIDTH=1280
DISPLAY_WINDOW_HEIGHT=720

# Visualization Options
DISPLAY_DRAW_BOXES=true
DISPLAY_BOX_THICKNESS=2
DISPLAY_DRAW_TRACK_IDS=true
DISPLAY_ID_FONT_SIZE=0.8
DISPLAY_DRAW_TRAILS=true
DISPLAY_TRAIL_LENGTH=30
DISPLAY_SHOW_STATS=true
DISPLAY_COLOR_PALETTE=auto

# =============================================================================
# PERFORMANCE CONFIGURATION
# =============================================================================

# Processing Settings
PERFORMANCE_BATCH_SIZE=1
PERFORMANCE_NUM_WORKERS=4
PERFORMANCE_MEMORY_EFFICIENT=true
PERFORMANCE_STATS_INTERVAL=100

# =============================================================================
# DEBUG CONFIGURATION
# =============================================================================

# Debug Options
DEBUG_ENABLED=false
DEBUG_SAVE_INTERMEDIATE=false
DEBUG_ENABLE_PROFILING=false
DEBUG_VERBOSE=false

# =============================================================================
# ADVANCED CONFIGURATION
# =============================================================================

# Custom Configuration File (overrides above settings)
# CONFIG_FILE=configs/custom.yml

# Network Configuration (if using RTSP)
# RTSP_TIMEOUT=10
# RTSP_BUFFER_SIZE=1024

# Model Download Settings
# AUTO_DOWNLOAD_MODELS=true
# MODEL_DOWNLOAD_URL=https://github.com/Megvii-BaseDetection/YOLOX/releases/download/0.1.1rc0/

# =============================================================================
# EXAMPLE CONFIGURATIONS
# =============================================================================

# Example 1: Webcam real-time detection
# INPUT_TYPE=webcam
# INPUT_SOURCE=0
# DISPLAY_SHOW_REALTIME=true
# OUTPUT_SAVE_FRAMES=false

# Example 2: Video file processing
# INPUT_TYPE=video
# INPUT_SOURCE=data/test_video.mp4
# OUTPUT_VIDEO_PATH=output/videos/processed_video.mp4
# OUTPUT_TRACKING_DATA=true

# Example 3: RTSP stream processing
# INPUT_TYPE=rtsp
# INPUT_SOURCE=rtsp://admin:password@192.168.1.100:554/stream
# DISPLAY_SHOW_REALTIME=true
# OUTPUT_SAVE_FRAMES=true

# Example 4: High accuracy configuration
# YOLOX_MODEL_SIZE=yolox_l
# YOLOX_CONFIDENCE_THRESHOLD=0.3
# YOLOX_NMS_THRESHOLD=0.3
# BYTETRACK_TRACK_THRESH=0.4
# BYTETRACK_HIGH_THRESH=0.5

# Example 5: Performance optimized
# YOLOX_MODEL_SIZE=yolox_s
# YOLOX_INPUT_SIZE=416,416
# PERFORMANCE_BATCH_SIZE=2
# PERFORMANCE_MEMORY_EFFICIENT=true